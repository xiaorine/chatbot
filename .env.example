# API Keys for LiteLLM (Gemini, OpenAI, DeepSeek, Claude, etc.)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# XiaomiMiMo Custom Provider Configuration
XIAOMIMIMO_API_KEY=your_xiaomimimo_api_key_here
XIAOMIMIMO_API_BASE=https://token-plan-sgp.xiaomimimo.com/v1

# GPM Login / CDP Configuration
# If using GPM API to start profiles automatically:
GPM_API_URL=http://127.0.0.1:9495
GPM_PROFILE_ID=your_gpm_profile_id_here

# If connecting directly to an already running browser (default):
GPM_DEBUG_PORT=9222
